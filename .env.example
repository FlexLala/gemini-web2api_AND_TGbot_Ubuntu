# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id
BOT_USERNAME=your_bot_username_without_at

# Модели по умолчанию (формат: provider:model)
DEFAULT_MODEL=groq:llama-3.3-70b-versatile
INLINE_MODEL=groq:llama-3.3-70b-versatile

# Groq (free tier, 14,400 req/day, no card)
GROQ_API_KEY=

# OpenRouter (free tier, 50 req/day)
OPENROUTER_API_KEY=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

# gemini-web2api fallback
GEMINI_WEB2API_URL=http://gemini-api:8081/v1/chat/completions

# DeepSeek (optional)
DEEPSEEK_API_KEY=

# Timeouts
GEMINI_CONNECT_TIMEOUT=10
GEMINI_READ_TIMEOUT=60
GEMINI_WRITE_TIMEOUT=60
GEMINI_POOL_TIMEOUT=30
GEMINI_RETRIES=2
GEMINI_MAX_CONCURRENT=3
GEMINI_MAX_CONNECTIONS=10
GEMINI_MAX_TOKENS=4096
GEMINI_INLINE_MAX_TOKENS=1400
GEMINI_HISTORY_MESSAGES=24
GEMINI_HISTORY_CHARS=30000
TELEGRAM_CONCURRENT_UPDATES=16
STREAMING_ENABLED=true
HEALTHCHECK_TIMEOUT=10
